# Example env file for reference (do NOT store real keys here in repo)

# Google Apps Script Email Service (Primary + Backup for 200 emails/day)
VITE_EMAIL_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
VITE_EMAIL_API_URL_BACKUP=https://script.google.com/macros/s/YOUR_BACKUP_SCRIPT_ID/exec
VITE_EMAIL_API_TOKEN=your_secret_token_here

# Legacy EmailJS (deprecated)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=service_xxx
VITE_EMAILJS_TEMPLATE_ID=template_xxx
VITE_EMAILJS_CREDENTIALS_TEMPLATE_ID=template_credentials_xxx

# Supabase (example)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
