# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always have LF line endings
*.sh text eol=lf
*.command text eol=lf

# Keep Windows batch files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# JSON files
*.json text eol=lf

# TypeScript/JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# CSS
*.css text eol=lf

# HTML
*.html text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
